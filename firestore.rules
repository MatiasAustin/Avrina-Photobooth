rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Check if user is an admin (we'll use a collection of admins for this)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Events
    match /events/{eventId} {
      allow read: if true; // Publicly readable for the kiosk
      allow write: if isAdmin();
      
      match /templates/{templateId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Sessions
    match /sessions/{sessionId} {
      allow create: if isSignedIn() && 
        incoming().eventId is string &&
        incoming().paymentStatus in ['pending', 'paid', 'free'] &&
        incoming().createdAt == request.time;
      
      allow read: if isSignedIn(); // Session read for kiosk and admin
      allow update: if isSignedIn() && (
        isAdmin() || 
        // Kiosk updates: adding photos or updating payment/template
        (incoming().diff(existing()).affectedKeys().hasOnly(['photos', 'enhancedPhotos', 'templateId', 'paymentStatus', 'paymentId']))
      );
    }

    // Print Queue
    match /printQueue/{jobId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Admin collection - only manageable by existing admins or initial setup
    match /admins/{adminId} {
      allow read: if isSignedIn();
      // Allow the very first admin to be created if none exist
      allow create: if isSignedIn() && (!exists(/databases/$(database)/documents/admins/$(request.auth.uid))); 
      allow update, delete: if isAdmin();
    }
  }
}
